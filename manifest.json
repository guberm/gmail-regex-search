{
  "manifest_version": 3,
  "name": "Gmail Regex Search",
  "version": "2.0",
  "description": "Regex-powered Gmail search — filter visible emails or search your entire inbox via Gmail API.",
  "icons": {
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "identity",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://gmail.googleapis.com/*"
  ],
  "action": {
    "default_title": "Gmail Regex Search",
    "default_icon": { "128": "icon128.png" }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
